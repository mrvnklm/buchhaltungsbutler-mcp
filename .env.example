# BuchhaltungsButler API credentials
BB_API_CLIENT=your_api_client
BB_API_SECRET=your_api_secret
BB_API_KEY=your_api_key

# Optional tuning (defaults shown; uncomment to override)
# BB_API_BASE_URL=https://webapp.buchhaltungsbutler.de/api/v1
# BB_RETRY_MAX_ATTEMPTS=3
# BB_RETRY_BASE_DELAY_MS=1000
# BB_RETRY_MAX_DELAY_MS=8000

# Allow upload_receipt to read local files via file:// URLs from these
# directories (path-delimiter separated: ':' on Linux/macOS, ';' on Windows).
# Unset by default = file:// uploads disabled.
# BB_ALLOWED_FILE_DIRS=/path/to/receipts:/another/dir
